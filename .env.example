# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000

# ── Banco de dados (Turso) ────────────────────────────────────────────────────
# Sem essas vars o servidor usa SQLite local em public/midia/db.sqlite (dev)
TURSO_URL=libsql://seu-banco.turso.io
TURSO_TOKEN=seu-token-jwt

# ── Armazenamento de arquivos (Cloudinary) ────────────────────────────────────
# Sem essas vars os uploads ficam no disco local em public/midia/uploads/ (dev)
CLOUDINARY_CLOUD_NAME=seu-cloud-name
CLOUDINARY_API_KEY=sua-api-key
CLOUDINARY_API_SECRET=seu-api-secret

# ── Autenticacao ──────────────────────────────────────────────────────────────
LOGIN_USER=Maria Pateis
LOGIN_PASS=UpConsult@25
